<mapper namespace="com.hms.main.jotdown.mapper.HsmJotdownMapper">
    
    <resultMap type="HsmJotdown" id="HsmJotdownResult">
        <result property="id"    column="id"    />
        <result property="personnel"    column="personnel"    />
        <result property="auxiliaryAccounting"    column="auxiliary_accounting"    />
        <result property="description"    column="description"    />
        <result property="amount"    column="amount"    />
        <result property="date"    column="date"    />
        <result property="accountingPeriod"    column="accounting_period"    />
        <result property="expenseType"    column="expense_type"    />
        <result property="remarks"    column="remarks"    />
        <result property="createdAt"    column="created_at"    />
        <result property="updatedAt"    column="updated_at"    />
