    </update>

    <delete id="deleteHsmJotdownById" parameterType="Long">
        delete from hsm_jotdown where id = #{id}
    </delete>

    <delete id="deleteHsmJotdownByIds" parameterType="String">
        delete from hsm_jotdown where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>